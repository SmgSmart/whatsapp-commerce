# Frontend, exposed by Vite. Do not put private secrets in VITE_* values.
VITE_API_BASE_URL=http://localhost:8787
VITE_NEON_AUTH_URL=
VITE_CLOUDINARY_CLOUD_NAME=

# Backend server.
PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# Neon Postgres.
# Use the pooled connection string from Neon Console > Connect for app traffic.
DATABASE_URL=
# Optional: use the direct/non-pooled connection string for migrations or SQL tools.
DATABASE_URL_DIRECT=

# Neon Auth.
# Neon/Vercel integrations use these names for branch-aware Auth URLs.
NEON_AUTH_BASE_URL=
# Generate locally with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=
# Temporary local bridge until Neon Auth session verification is connected.
# Use the Neon Auth user id that owns your first test store.
DEV_ADMIN_USER_ID=9cf33718-487f-4340-8bd9-9aa38cab6af2

# Cloudinary.
# Preferred by the official Node SDK. Format:
# cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# Optional split values if the backend code configures Cloudinary manually.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
